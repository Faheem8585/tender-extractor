# DeepSeek API key — get yours at platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_key_here

# Provider settings
LLM_PROVIDER=deepseek
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Chunking — reduce CHUNK_SIZE_CHARS for dense technical tenders (e.g. 1500)
CHUNK_SIZE_CHARS=3000
CHUNK_OVERLAP_CHARS=300

# Extraction
MAX_RETRIES=3
EXTRACTION_BATCH_SIZE=3
EXTRACTION_CONCURRENCY=5

# Consolidation
CONSOLIDATION_BATCH_SIZE=30
CONSOLIDATION_CONCURRENCY=5

# Tree building
TREE_L2_BATCH_SIZE=120
TREE_CONCURRENCY=5
LLM_MAX_CONCURRENT=5
